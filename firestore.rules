rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users_scores/{playerId} {
      // Signed-in players can read the leaderboard / tournament ranks.
      allow read: if request.auth != null;

      // Doc id = stable browser playerId (localStorage), not necessarily auth.uid.
      allow create, update: if request.auth != null
        && request.resource.data.playerId == playerId
        && request.resource.data.totalScore is int
        && request.resource.data.totalScore >= 0
        && request.resource.data.authUid == request.auth.uid;

      allow delete: if false;
    }

    // Admin-managed landing promo + confirmed winner (read-only for players).
    match /game_metadata/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // 12h window snapshots of users_scores (kept ~2 days for winner audit).
    match /score_archives/{archiveId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.authUid == request.auth.uid
        && request.resource.data.playerId is string
        && request.resource.data.cycleId is string
        && request.resource.data.totalScore is int
        && request.resource.data.tournamentScore is int
        && request.resource.data.expireAt is timestamp
        && archiveId ==
            request.resource.data.cycleId + '_' + request.resource.data.playerId;

      allow update: if false;

      // Any signed-in client may purge expired archive docs.
      allow delete: if request.auth != null
        && resource.data.expireAt is timestamp
        && resource.data.expireAt <= request.time;
    }

    // Claim doc id = stable users_scores id (== confirmed_winner.uid).
    // Contact-only payload — score fields are forbidden.
    match /winners_claims/{claimId} {
      // CRITICAL: missing docs have resource == null. Old rules required
      // resource.data.authUid and blocked the winner from detecting "not claimed",
      // which hid the celebration UI. Allow get only for the announced winner
      // path when empty, or for the claim owner when the doc exists.
      allow get: if request.auth != null && (
        (
          resource == null
          && claimId ==
              get(/databases/$(database)/documents/game_metadata/confirmed_winner)
                .data.uid
        )
        || (resource != null && resource.data.authUid == request.auth.uid)
      );

      allow list: if false;

      allow create: if request.auth != null
        && claimId ==
            get(/databases/$(database)/documents/game_metadata/confirmed_winner)
              .data.uid
        && request.resource.data.playerId == claimId
        && request.resource.data.uid == claimId
        && request.resource.data.authUid == request.auth.uid
        && request.resource.data.isProcessed == false
        && request.resource.data.fullName is string
        && request.resource.data.upiId is string
        && request.resource.data.fullName.size() > 0
        && request.resource.data.upiId.size() > 0
        && !('totalScore' in request.resource.data)
        && !('highScore' in request.resource.data)
        && !('tournamentScore' in request.resource.data)
        && !('lastRunScore' in request.resource.data);

      allow update, delete: if false;
    }
  }
}
